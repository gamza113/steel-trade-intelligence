# Production API (Railway)
NODE_ENV=production
API_HOST=0.0.0.0

# Railway sets PORT automatically — do not hardcode in production.
# API_PORT is only used when PORT is unset (local production smoke tests).

# Frontend origin(s) — required for browser API calls from Vercel
# Use your Vercel production URL and optional preview pattern via multiple origins:
CORS_ORIGIN=https://your-app.vercel.app
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# Railway PostgreSQL (set automatically when the database service is linked)
DATABASE_URL=postgresql://user:password@host:port/railway
# DATABASE_SSL=true

# Optional pool tuning for managed Postgres
# DATABASE_POOL_MAX=10
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_CONNECTION_TIMEOUT_MS=10000

# Auth (future use)
JWT_SECRET=replace-with-long-random-secret

# Optional
# REDIS_URL=
