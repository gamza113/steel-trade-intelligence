# Production frontend (Vercel)
# Set these in the Vercel project dashboard under Settings → Environment Variables.

# Public Railway API base URL (must include /api/v1 suffix)
VITE_API_BASE_URL=https://your-api.up.railway.app/api/v1

# Alternate env name (optional fallback)
# VITE_API_URL=https://your-api.up.railway.app/api/v1

# Mapbox token for the companies map
VITE_MAPBOX_ACCESS_TOKEN=
