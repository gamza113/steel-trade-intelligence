# Application
NODE_ENV=development
APP_NAME=Steel Trade Intelligence Platform

# API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Database (local Docker Compose)
DATABASE_URL=postgresql://stip:stip@localhost:5432/stip_dev
# DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Object Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=stip-uploads
S3_ACCESS_KEY=stip
S3_SECRET_KEY=stipsecret
S3_REGION=us-east-1

# Mapbox (frontend — see frontend/.env.example)
VITE_MAPBOX_ACCESS_TOKEN=

# Production deployment: see docs/DEPLOYMENT.md
